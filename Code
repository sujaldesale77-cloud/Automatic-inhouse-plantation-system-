// ---- Manual Time Setup ----
struct tm currentTime;
void setManualTime() {
  currentTime.tm_year = 2025 - 1900;
  currentTime.tm_mon = 9;
  currentTime.tm_mday = 13;
  currentTime.tm_hour = 12;
  currentTime.tm_min = 0;
  currentTime.tm_sec = 0;
  time_t now = mktime(&currentTime);
  struct timeval tv = { now, 0 };
  settimeofday(&tv, NULL);
}

// ---- DHT22 Functions ----
uint8_t dhtData[5];
bool readDHT22() {
  uint8_t bits[40]; uint8_t i, j;
  pinMode(DHTPIN, OUTPUT); digitalWrite(DHTPIN, LOW); delay(1);
  digitalWrite(DHTPIN, HIGH); delayMicroseconds(30); pinMode(DHTPIN, INPUT);

  unsigned int loopCnt = 10000;
  while(digitalRead(DHTPIN)==HIGH && loopCnt--) delayMicroseconds(1);
  if(loopCnt==0) return false;
  loopCnt=10000;
  while(digitalRead(DHTPIN)==LOW && loopCnt--) delayMicroseconds(1);
  if(loopCnt==0) return false;
  loopCnt=10000;
  while(digitalRead(DHTPIN)==HIGH && loopCnt--) delayMicroseconds(1);
  if(loopCnt==0) return false;

  for(i=0;i<40;i++){
    loopCnt=10000;
    while(digitalRead(DHTPIN)==LOW && loopCnt--) delayMicroseconds(1);
    if(loopCnt==0) return false;
    unsigned long t=micros();
    loopCnt=10000;
    while(digitalRead(DHTPIN)==HIGH && loopCnt--) delayMicroseconds(1);
    if(loopCnt==0) return false;
    bits[i] = (micros()-t) > 40 ? 1 : 0;
  }

  for(i=0;i<5;i++){
    dhtData[i]=0;
    for(j=0;j<8;j++){
      dhtData[i]<<=1;
      dhtData[i]|=bits[i*8+j];
    }
  }

  if(dhtData[4] != ((dhtData[0]+dhtData[1]+dhtData[2]+dhtData[3]) & 0xFF)) return false;
  return true;
}

void updateDHT22() {
  if(readDHT22()){
    humidity=((dhtData[0]<<8)+dhtData[1])*0.1;
    temperature=(((dhtData[2]&0x7F)<<8)+dhtData[3])*0.1;
    if(dhtData[2]&0x80) temperature=-temperature;
    dhtMsg="DHT22 data updated.";

    if(humidity<HUMIDITY_LOW){ 
      digitalWrite(MIST_MAKER_RELAY,LOW); 
      mistMakerState=true; 
      mistMsg="Humidity is low. Mist maker ON.";
    }
    else{ 
      digitalWrite(MIST_MAKER_RELAY,HIGH); 
      mistMakerState=false; 
      mistMsg="Humidity OK. Mist maker OFF.";
    }
  }else{
    dhtMsg="Failed to read DHT22.";
  }
}

// ---- MQ Gas Sensor (CO2) ----
void readMQSensor() {
  int sensorValue = analogRead(MQ_AOUT);
  int co2Content = sensorValue - 2000;
  if(co2Content<0) co2Content=0;
  mqVoltage = sensorValue*(3.3/4095.0);
  mqValue = co2Content;
  mqMsg="CO2 content read successfully.";
}

// ---- TDS and pH ----
void runMotor(int pin,bool &state){
  digitalWrite(pin,LOW); 
  state=true; 
  delay(MOTOR_RUN_TIME); 
  digitalWrite(pin,HIGH); 
  state=false;
}

void measureTDS(){
  int val=analogRead(TDS_PIN);
  tdsValue=map(val,0,4095,300,800);

  if(tdsValue<TDS_LOW){
    tdsMsg="Nutrient low. Pump ON.";
    runMotor(TDS_MOTOR_PIN,tdsMotorState);
    tdsMsg="Pump OFF.";
  }
  else if(tdsValue>TDS_HIGH) tdsMsg="TDS high, stable.";
  else tdsMsg="TDS optimal.";
}

void measurePH(){
  int raw=analogRead(PH_PIN);
  float voltage=(raw/ADC_RES)*VREF;
  phValue=PH_SLOPE*voltage+PH_OFFSET;

  if(phValue<PH_LOW||phValue>PH_HIGH){
    phMsg="pH out of range. Pump ON.";
    runMotor(PH_MOTOR_PIN,phMotorState);
    phMsg="pH stabilized. Pump OFF.";
  }
  else phMsg="pH optimal.";
}

// ---- Water Level ----
void checkWaterLevels(){
  int r1=analogRead(WATER_LEVEL1_PIN);
  int r2=analogRead(WATER_LEVEL2_PIN);
  int r3=analogRead(WATER_LEVEL3_PIN);

  waterLevel1=r1;
  waterLevel2=r2;
  waterLevel3=r3;

  waterLevelMsg1=(r1<WATER_LEVEL_THRESHOLD)?"Water Level 1 LOW":"Water Level 1 OK";
  waterLevelMsg2=(r2<WATER_LEVEL_THRESHOLD)?"Water Level 2 LOW":"Water Level 2 OK";
  waterLevelMsg3=(r3<WATER_LEVEL_THRESHOLD)?"Water Level 3 LOW":"Water Level 3 OK";
}

