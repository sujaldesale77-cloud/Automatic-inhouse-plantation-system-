// ---- Setup ----
void setup(){
  Serial.begin(115200);

  pinMode(TDS_PIN, INPUT); 
  pinMode(PH_PIN, INPUT); 
  pinMode(MQ_AOUT, INPUT);
  pinMode(TDS_MOTOR_PIN, OUTPUT); 
  pinMode(PH_MOTOR_PIN, OUTPUT); 
  pinMode(GROW_LIGHT_RELAY, OUTPUT);
  pinMode(PELTIER_RELAY, OUTPUT); 
  pinMode(WATER_PUMP_RELAY, OUTPUT); 
  pinMode(MIST_MAKER_RELAY, OUTPUT);
  pinMode(EXHAUST_FAN_RELAY, OUTPUT); 
  pinMode(LED_PIN, OUTPUT);
  pinMode(WATER_LEVEL1_PIN, INPUT); 
  pinMode(WATER_LEVEL2_PIN, INPUT); 
  pinMode(WATER_LEVEL3_PIN, INPUT);

  digitalWrite(TDS_MOTOR_PIN,HIGH); 
  digitalWrite(PH_MOTOR_PIN,HIGH); 
  digitalWrite(GROW_LIGHT_RELAY,HIGH);
  digitalWrite(PELTIER_RELAY,HIGH); 
  digitalWrite(MIST_MAKER_RELAY,HIGH); 
  digitalWrite(EXHAUST_FAN_RELAY,HIGH);
  digitalWrite(WATER_PUMP_RELAY,LOW);

  WiFi.begin(ssid,password);
  Serial.print("Connecting to Wi-Fi");
  while(WiFi.status()!=WL_CONNECTED){ 
    delay(500); 
    Serial.print("."); 
  }
  Serial.println(); 
  Serial.print("Connected! IP: "); 
  Serial.println(WiFi.localIP());

  setManualTime();
  server.on("/",handleRoot);
  server.begin();
  Serial.println("Web Server started!");
}

// ---- Loop ----
void loop(){
  server.handleClient();
  unsigned long currentMillis=millis();

  if(currentMillis-lastTDSMeasure>=TDS_INTERVAL){ 
    lastTDSMeasure=currentMillis; 
    measureTDS(); 
  }

  if(currentMillis-lastPHMeasure>=PH_INTERVAL){ 
    lastPHMeasure=currentMillis; 
    measurePH(); 
  }

  if(currentMillis-lastDHTRead>=10000){ 
    lastDHTRead=currentMillis; 
    updateDHT22(); 
  }

  if(currentMillis-lastWaterLevelCheck>=WATER_LEVEL_INTERVAL){ 
    lastWaterLevelCheck=currentMillis; 
    checkWaterLevels(); 
  }

  if(currentMillis-lastMQRead>=MQ_INTERVAL){ 
    lastMQRead=currentMillis; 
    readMQSensor(); 
  }

  if(currentMillis-lastSheetSend>=SHEET_INTERVAL){ 
    lastSheetSend=currentMillis; 
    sendToGoogleSheet(); 
  }

  time_t now=time(nullptr);
  struct tm *timeinfo=localtime(&now);
  int hour=timeinfo->tm_hour;

  if(hour>=9 && hour<17){
    digitalWrite(GROW_LIGHT_RELAY,LOW); 
    growLightState=true; 
    digitalWrite(PELTIER_RELAY,LOW); 
    peltierState=true;
  }
  else{
    digitalWrite(GROW_LIGHT_RELAY,HIGH); 
    growLightState=false; 
    digitalWrite(PELTIER_RELAY,HIGH); 
    peltierState=false;
  }

  if((currentMillis-lastFanRun>=FAN_INTERVAL)&&!exhaustFanState){
    digitalWrite(EXHAUST_FAN_RELAY,LOW); 
    exhaustFanState=true; 
    fanStartTime=currentMillis; 
    fanMsg="Fan ON for 5 min";
  }

  if(exhaustFanState && (currentMillis-fanStartTime>=FAN_RUN_TIME)){
    digitalWrite(EXHAUST_FAN_RELAY,HIGH); 
    exhaustFanState=false; 
    lastFanRun=currentMillis; 
    fanMsg="Fan OFF";
  }
  // ---- SEND SENSOR VALUES TO ARDUINO FOR LCD ----
Serial.print("TDS:");
Serial.print(tdsValue);
Serial.print(",PH:");
Serial.print(phValue, 2);
Serial.print(",TEMP:");
Serial.print(temperature, 1);
Serial.print(",HUM:");
Serial.print(humidity, 1);
Serial.print(",CO2:");
Serial.println(mqValue);

}